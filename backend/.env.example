# ===== Server =====
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins for CORS
CLIENT_URL=http://localhost:5173

# ===== MongoDB Atlas =====
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/chitram?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/chitram?retryWrites=true&w=majority

# ===== JWT =====
JWT_ACCESS_SECRET=your_strong_random_access_secret
JWT_REFRESH_SECRET=your_strong_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== OpenAI (AI features: tagging, embeddings, recommendations, similarity) =====
# Optional. If left blank, AI features gracefully degrade (no auto-tags / embeddings).
OPENAI_API_KEY=your_openai_api_key
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Set to "true" if you have created an Atlas Vector Search index named "work_vector_index"
# on the Work collection's `embedding` field (1536 dims, cosine). If false, the app uses
# an in-memory cosine similarity fallback so similarity/recommendations still work.
USE_ATLAS_VECTOR_SEARCH=false
